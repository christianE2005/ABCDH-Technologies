{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "build": {
    "env": {
      "VITE_API_TARGET": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://abcdhtechnologiesbackend-production-f379.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
